{
  "manifest_version": 3,
  "name": "ChatGPT Context Bridge for Codex",
  "version": "0.1.0",
  "description": "Send ChatGPT conversation context to a local Codex project through a local Bridge.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "http://127.0.0.1:17321/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ChatGPT Context Bridge"
  },
  "background": {
    "service_worker": "serviceWorker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
